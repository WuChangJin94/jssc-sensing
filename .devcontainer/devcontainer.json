{
  "name": "moos-dawg-2024-dev",
  "image": "argnctu/moos-dawg-2024:ubuntu20.04-gpu",
  "runArgs": [
    "--gpus", "all",
    "--runtime=nvidia",
    "--env", "DISPLAY",
    "--env", "XAUTHORITY=/tmp/.docker.xauth",
    "--env", "HOME=/home/moos-dawg",
    "--env", "OPENAI_API_KEY=${localEnv:OPENAI_API_KEY}",
    "--env", "NVIDIA_DRIVER_CAPABILITIES=all",
    "--env", "USER=root",
    "--volume", "/tmp/.X11-unix:/tmp/.X11-unix",
    "--volume", "/etc/localtime:/etc/localtime:ro",
    "--volume", "/dev:/dev",
    "--volume", "/var/run/docker.sock:/var/run/docker.sock",
    "--network", "host",
    "--privileged",
    "--security-opt", "seccomp=unconfined",
    "--user", "root:root"
  ],
  "mounts": [
    "source=${localEnv:HOME}/moos-dawg-2024,target=/home/moos-dawg/moos-dawg-2024,type=bind",
    "source=/tmp/.docker.xauth,target=/tmp/.docker.xauth,type=bind"
  ],
  "workspaceFolder": "/home/moos-dawg/moos-dawg-2024",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "extensions": [
    "ms-python.python",
    "ms-toolsai.jupyter",
    "ms-vscode.cpptools",
    "ms-azuretools.vscode-docker",
    "tomoki1207.pdf",
    "redhat.vscode-xml"
  ],
  "postCreateCommand": "pip install ipykernel",
  "shutdownAction": "none"
}
