<?xml version="1.0"?>
<package format="2">
  <name>kc1400_driver</name>
  <version>0.0.1</version>
  <description>KC-1400 GNSS compass driver and multicast bridge.</description>

  <maintainer email="you@example.com">KC1400 Maintainer</maintainer>
  <license>BSD</license>

  <buildtool_depend>catkin</buildtool_depend>

  <!-- Runtime + build dependencies -->
  <depend>rospy</depend>
  <depend>std_msgs</depend>
  <depend>sensor_msgs</depend>
  <depend>geometry_msgs</depend>
  <depend>nav_msgs</depend>
  <depend>nmea_msgs</depend>

  <export/>
</package>

